{
  "name": "sleep-alarm-detector-server",
  "version": "1.0.0",
  "description": "Backend API for Sleep Alarm Detector",
  "main": "dist/index.js",
  "type": "commonjs",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
